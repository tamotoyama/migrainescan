# Firebase Web SDK — get these from Firebase Console > Project Settings > Your apps > Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# RevenueCat — get from RevenueCat Dashboard > Project > API Keys > Public Apple API key
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=

# OpenFoodFacts — set a descriptive user agent for API requests
EXPO_PUBLIC_OPENFOODFACTS_USER_AGENT=MigraineScan/1.0 (com.migrainescan.app)

# EAS — get from Expo Dashboard after linking the project
EAS_PROJECT_ID=
